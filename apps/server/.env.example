#EXAMPLE ENV FILE WITH DUMMY VALUES, well... for example
DB_URL="postgresql://POSTGRES_USER:PASSWORD@localhost:DATABASE_PORT/DATABASE_NAME?sslmode=disable" #your DB URL str to init sqlmodel engine or the supabase ipv4 one
TEST_DB_URL="postgresql://POSTGRES_USER:PASSWORD@localhost:DATABASE_PORT/DATABASE_NAME?sslmode=disable"
DEBUG="False" #debug mode for sqlmodel engine (shows executed sql queries)
MODEL_NAME="openai/gpt-oss-120b" #your llm of your choosing
BASE_URL="https://api.groq.com/openai/v1" #definitely needed, do not change
GROQ_API_KEY="YOUR KEY HERE" # cause using groq
CORS_ORIGINS="http://127.0.0.1:8000,http://127.0.0.1:3000,https://some-site.com" #no spaces, separated by commas expo
