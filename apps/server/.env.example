#EXAMPLE ENV FILE WITH DUMMY VALUES, well... for example
DB_URL="postgresql+psycopg://POSTGRES_USER:PASSWORD@localhost:DATABASE_PORT/DATABASE_NAME?sslmode=disable" #your DB URL str to init sqlmodel engine or the supabase ipv4 one
TEST_DB_URL="postgresql+psycopg://POSTGRES_USER:PASSWORD@localhost:DATABASE_PORT/DATABASE_NAME?sslmode=disable" #needs to have +psycopg for async support
DEBUG="False" #debug mode for sqlmodel engine (shows executed sql queries)
MODEL_NAME="openai/gpt-oss-120b" #your llm of your choosing
BASE_URL="https://api.groq.com/openai/v1" #definitely needed, do not change
GROQ_API_KEY="YOUR KEY HERE" # cause using groq
CORS_ORIGINS="http://127.0.0.1:8000,http://127.0.0.1:3000,https://some-site.com" #no spaces, separated by commas expo
ACCESS_TOKEN_SECRET="example-only-secret-never-use-this-in-production" #signs the JWT so attackers cannot create valid tokens themselves.
ACCESS_TOKEN_LIFETIME_SECONDS="3600"#How long JWT remains valid
ACCESS_COOKIE_NAME="procradicator_access"#Browser cookie name
ACCESS_COOKIE_SECURE="True"#Only allows cookie to be sent over HTTPS
GOOGLE_OAUTH_CLIENT_ID="google-oauth-client-id"#Tells Google which app is asking for login
GOOGLE_OAUTH_CLIENT_SECRET="google-oauth-client-secret"#Secret from Google for backend to complete OAuth
OAUTH_STATE_SECRET="replace-with-a-random-oauth-state-secret"#Protect OAuth flow
OAUTH_COOKIE_SECURE="False"#Temp OAuth CSRF cookie requires HTTPS or not
